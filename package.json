{
  "name": "agentping",
  "version": "0.7.0",
  "description": "Notify when your AI agents finish and send concise completion summaries.",
  "private": false,
  "keywords": [
    "agent",
    "codex",
    "claude-code",
    "openclaw",
    "hermes-agent",
    "notification",
    "pushdeer",
    "notifier",
    "automation"
  ],
  "author": {
    "name": "AgentPing contributors"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/planetInGalaxy/agentping.git"
  },
  "type": "module",
  "bin": {
    "agentping": "bin/agentping.mjs",
    "codex-pushdeer": "bin/codex-pushdeer.mjs"
  },
  "files": [
    ".agents/",
    "bin/",
    "plugins/",
    "integrations/",
    "!integrations/**/__pycache__/**",
    "!integrations/**/*.pyc",
    "scripts/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "check": "find plugins scripts bin integrations/openclaw -name '*.mjs' -print0 | xargs -0 -n1 node --check && python3 -c \"import ast,pathlib; ast.parse(pathlib.Path('integrations/hermes/__init__.py').read_text())\"",
    "install:local": "node scripts/install-local.mjs",
    "setup": "node scripts/install.mjs",
    "uninstall:notifier": "node scripts/uninstall.mjs",
    "doctor": "node scripts/doctor.mjs",
    "config": "node scripts/config.mjs",
    "logs": "node scripts/logs.mjs",
    "test:notifier": "node scripts/test-notifier.mjs",
    "check-models": "node scripts/check-models.mjs",
    "plugin:validate": "node scripts/validate-plugin.mjs",
    "config:show": "node scripts/config.mjs show",
    "notify:dry-run": "AGENTPING_DRY_RUN=1 node plugins/agentping/scripts/pushdeer-notify.mjs --title 已完成AgentPing本地通知脚本dryrun验证当前不会真实发送消息"
  }
}
